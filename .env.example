# ============================================================================
# Portal News — Configuração de Ambiente
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
#   cp .env.example .env

# ----------------------------------------------------------------------------
# BANCO DE DADOS
# ----------------------------------------------------------------------------
# MySQL/MariaDB (banco principal)
DATABASE_URL=mysql://root:@127.0.0.1:3306/pnews

# Segredo-base para hashing, rate limits e outros controles internos.
APP_SECURITY_SECRET=substitua-por-um-segredo-longo-e-aleatorio
# Opcional: chave dedicada para criptografia de credenciais. Se vazia, usa APP_SECURITY_SECRET.
# CREDENTIAL_ENCRYPTION_SECRET=substitua-por-outro-segredo-longo

# Assina eventos públicos de impressão/clique de anúncios. Use um valor longo e aleatório.
AD_TRACKING_SECRET=substitua-por-um-segredo-longo-e-aleatorio

# Autoriza rotinas agendadas via cabeçalho Authorization: Bearer.
CRON_SECRET=substitua-por-um-segredo-longo-e-aleatorio

# Retenção de métricas detalhadas de acesso (mínimo 30, padrão 365 dias).
ANALYTICS_RETENTION_DAYS=365

# ----------------------------------------------------------------------------
# OPCIONAL — DEPLOY TARGET
# ----------------------------------------------------------------------------
# Deixe vazio para deploy standalone (VPS, Docker, space-z.ai)
# Use "serverless" para Vercel/Netlify/Cloudflare
# DEPLOY_TARGET=serverless

# ----------------------------------------------------------------------------
# NOTAS
# ----------------------------------------------------------------------------
# - Após definir DATABASE_URL, rode:
#     npm install
#     npm run db:push      (cria as tabelas)
#     npm run build        (build de produção)
#     npm start            (inicia servidor em produção)
#
# - Para desenvolvimento:
#     npm install
#     npm run dev          (inicia em http://localhost:3000)
#
# - Para migrar uma base SQLite antiga, preserve uma cópia e execute:
#     npm run db:mysql:migrate
